{
  "name": "pensjon-regler-beregn",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter bff dev\" \"pnpm --filter pensjon-regler-beregn-frontend dev\"",
    "build": "pnpm --filter @pensjon/domain build && pnpm --filter bff build && pnpm --filter pensjon-regler-beregn-frontend build",
    "start": "NODE_ENV=prod-gcp node bff/dist/server.js",
    "local": "NODE_ENV=prod-gcp dotenv -e app/bff/.env.prod-gcp -- node bff/dist/server.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.0"
  }
}
