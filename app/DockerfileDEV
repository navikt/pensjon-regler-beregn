FROM europe-north1-docker.pkg.dev/cgr-nav/pull-through/nav.no/node:22-dev AS base
USER root
WORKDIR /app

COPY package*.json ./
COPY .npmrc ./.npmrc
COPY bff/package*.json bff/
COPY bff/tsconfig*.json bff/
COPY frontend/package*.json frontend/
COPY frontend/tsconfig*.json frontend/


RUN --mount=type=secret,id=NODE_AUTH_TOKEN \
    npm config set //npm.pkg.github.com/:_authToken=$(cat /run/secrets/NODE_AUTH_TOKEN)
RUN npm config set @navikt:registry=https://npm.pkg.github.com
RUN npm ci

FROM base AS builder
ARG BUILD_ENV=dev-gcp
COPY . .
COPY bff/.env.dev-gcp /.env.dev-gcp
COPY frontend/.env.dev-gcp frontend/.env.dev-gcp
RUN npm run build --workspace @pensjon/domain
RUN npm run build --workspace frontend -- --mode ${BUILD_ENV}
RUN npm run build --workspace bff

RUN npm prune --omit=dev --ignore-scripts

FROM europe-north1-docker.pkg.dev/cgr-nav/pull-through/nav.no/node:22-slim AS runner
WORKDIR /app
ENV NODE_ENV=dev-gcp
ENV APP_ENV=dev-gcp
ENV PORT=8080
ENV TZ="Europe/Oslo"

COPY package*.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/bff/dist ./bff/dist
COPY --from=builder /app/frontend/dist ./frontend/dist
COPY --from=builder /.env.dev-gcp ./.env.dev-gcp

USER node
EXPOSE 8080
CMD ["bff/dist/server.js"]
